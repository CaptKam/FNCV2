<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>Dinner Party Timeline - Simmering</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Noto+Serif:ital,wght@0,400;0,600;0,700;1,400&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "outline-variant": "#ddc1b4",
                    "on-secondary-container": "#775e40",
                    "secondary-fixed": "#feddb7",
                    "on-tertiary-fixed-variant": "#004689",
                    "on-error-container": "#93000a",
                    "surface-bright": "#fef9f3",
                    "surface-variant": "#e6e2dc",
                    "primary-fixed": "#ffdbcb",
                    "outline": "#897267",
                    "error-container": "#ffdad6",
                    "tertiary": "#004485",
                    "on-tertiary": "#ffffff",
                    "on-primary": "#ffffff",
                    "background": "#fef9f3",
                    "surface-tint": "#9d4303",
                    "inverse-primary": "#ffb691",
                    "on-secondary-fixed-variant": "#594327",
                    "surface-dim": "#ded9d4",
                    "on-primary-fixed-variant": "#783100",
                    "inverse-surface": "#32302c",
                    "secondary-fixed-dim": "#e1c19d",
                    "tertiary-container": "#005caf",
                    "secondary": "#725a3c",
                    "on-tertiary-container": "#c0d6ff",
                    "surface-container-high": "#ece7e2",
                    "on-secondary": "#ffffff",
                    "on-error": "#ffffff",
                    "on-primary-fixed": "#341100",
                    "secondary-container": "#fbdab4",
                    "primary": "#753000",
                    "error": "#ba1a1a",
                    "primary-fixed-dim": "#ffb691",
                    "surface-container-low": "#f8f3ed",
                    "on-secondary-fixed": "#291802",
                    "surface-container-lowest": "#ffffff",
                    "surface": "#fef9f3",
                    "on-surface": "#1d1b18",
                    "on-tertiary-fixed": "#001b3c",
                    "on-surface-variant": "#564339",
                    "tertiary-fixed": "#d5e3ff",
                    "on-primary-container": "#ffc9af",
                    "surface-container-highest": "#e6e2dc",
                    "on-background": "#1d1b18",
                    "primary-container": "#9a4100",
                    "inverse-on-surface": "#f5f0ea",
                    "tertiary-fixed-dim": "#a7c8ff",
                    "surface-container": "#f2ede7"
            },
            "borderRadius": {
                    "DEFAULT": "0.25rem",
                    "lg": "0.5rem",
                    "xl": "0.75rem",
                    "full": "9999px"
            },
            "fontFamily": {
                    "headline": ["Noto Serif"],
                    "body": ["Inter"],
                    "label": ["Inter"]
            }
          },
        },
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .timer-ring {
            stroke-dasharray: 283;
            stroke-dashoffset: 70;
            transform: rotate(-90deg);
            transform-origin: 50% 50%;
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="bg-background text-on-background font-body min-h-screen flex flex-col items-center">
<!-- TopAppBar -->
<header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-5 py-4 bg-[#FEF9F3] dark:bg-[#0D0D0D] border-b-[0.5px] border-[#DEC1B3]/35">
<button class="hover:opacity-80 scale-95 duration-150 ease-in flex items-center justify-center h-10 w-10">
<span class="material-symbols-outlined text-[#9A4100] dark:text-[#FFB690]" data-icon="close">close</span>
</button>
<h1 class="font-headline font-bold text-xl text-[#9A4100] dark:text-[#FFB690]">Dinner Party Timeline</h1>
<button class="hover:opacity-80 scale-95 duration-150 ease-in flex items-center justify-center h-10 w-10">
<span class="material-symbols-outlined text-[#9A4100] dark:text-[#FFB690]" data-icon="more_horiz">more_horiz</span>
</button>
</header>
<!-- Main Content Canvas -->
<main class="w-full max-w-md pt-24 pb-32 px-5 flex flex-col items-center">
<!-- Section Header -->
<div class="w-full text-center mb-8">
<span class="font-label text-xs tracking-[1.5px] font-semibold text-secondary mb-2 block uppercase">CURRENT STEP</span>
<h2 class="font-headline text-[28px] font-bold text-on-surface leading-tight">Simmering</h2>
</div>
<!-- Circular Timer Component -->
<div class="relative flex items-center justify-center mb-12">
<!-- Tonal Background for Ring -->
<svg class="w-72 h-72">
<circle class="text-surface-container-high" cx="144" cy="144" fill="transparent" r="130" stroke="currentColor" stroke-width="8"></circle>
<circle class="timer-ring text-primary-container" cx="144" cy="144" fill="transparent" r="130" stroke="currentColor" stroke-linecap="round" stroke-width="8"></circle>
</svg>
<!-- Timer Text -->
<div class="absolute flex flex-col items-center">
<span class="font-headline text-5xl font-bold text-on-surface tracking-tighter">08:45</span>
<span class="font-label text-sm font-medium text-on-surface-variant mt-1">remaining</span>
</div>
</div>
<!-- Timer Controls -->
<div class="flex gap-4 w-full mb-10">
<button class="flex-1 h-[52px] rounded-[14px] bg-primary text-on-primary font-semibold text-[17px] flex items-center justify-center gap-2 hover:opacity-90 active:scale-95 transition-all">
<span class="material-symbols-outlined text-xl" data-icon="pause">pause</span>
                Pause
            </button>
<button class="flex-1 h-[52px] rounded-[14px] border border-primary/30 text-primary font-medium text-[17px] flex items-center justify-center gap-2 hover:bg-surface-container-low active:scale-95 transition-all">
<span class="material-symbols-outlined text-xl" data-icon="refresh">refresh</span>
                Reset
            </button>
</div>
<!-- Instruction Text -->
<div class="w-full bg-surface-container-low rounded-2xl p-6 mb-8 text-center">
<p class="font-body text-[17px] leading-[26px] text-on-surface">
                Simmer the tagine on low heat. This is a good time to prep your mint tea.
            </p>
</div>
<!-- Sous-Chef Tip Card (Asymmetric Layout) -->
<div class="w-full relative overflow-hidden bg-surface-container-highest rounded-[20px] p-6 flex gap-5">
<div class="flex-shrink-0 w-12 h-12 bg-primary-container/10 rounded-full flex items-center justify-center">
<span class="material-symbols-outlined text-primary-container" data-icon="lightbulb" style="font-variation-settings: 'FILL' 1;">lightbulb</span>
</div>
<div>
<h3 class="font-label text-sm font-bold text-primary mb-1 uppercase tracking-wider">Sous-Chef Tip</h3>
<p class="font-body text-[16px] text-on-surface-variant italic leading-relaxed">
                    "Keep the lid slightly ajar to let steam escape."
                </p>
</div>
<!-- Decorative Grain Texture / Glassmorphism accent -->
<div class="absolute -right-4 -bottom-4 w-24 h-24 bg-primary-container/5 rounded-full blur-2xl"></div>
</div>
<!-- Image bleed for editorial feel -->
<div class="w-full mt-12 mb-4">
<img alt="Tagine simmering" class="w-full aspect-[16/10] object-cover rounded-2xl shadow-sm" data-alt="Close-up of a traditional ceramic Moroccan tagine pot with aromatic steam rising from a slightly ajar lid, warm ambient kitchen lighting" src="https://lh3.googleusercontent.com/aida-public/AB6AXuA39zITTItt-wjm71Qjckvig4JgwDKJGCHustJzxNx14h1R0X_MZBIqgoXvgoZOSnGeeAymB3xDY7LJrYPpSrU-qrkyY054-RDrDOa9zzkIJ7DanfLA-cyEv7KnDGri15yzMGaqWnLaMcOGBHG0YOoh7Is6uSVlZlwZAAHgALjyetb92IaqeMkTNXm1brRpxRnCtAqt3aUPDTezRkjJzlAXsllnDtzwB-huQ5FNQnB9R4124FXmH__c0m2oM3-Jcnv5RT_wEacjHfWR"/>
</div>
</main>
<!-- BottomNavBar -->
<nav class="fixed bottom-0 left-0 w-full z-50 flex justify-between items-center bg-[#FEF9F3] dark:bg-[#0D0D0D] px-5 pb-8 pt-4 shadow-[0_-12px_40px_rgba(29,27,24,0.06)] dark:shadow-none">
<!-- Previous -->
<button class="flex flex-col items-center justify-center text-[#574238] dark:text-[#D7C2B5] px-6 py-3 hover:bg-[#ECE7E2] dark:hover:bg-[#252A32] duration-150 transition-all scale-95">
<span class="material-symbols-outlined mb-1" data-icon="arrow_back">arrow_back</span>
<span class="font-label text-[13px] font-semibold">Previous</span>
</button>
<!-- Timer (Active) -->
<button class="flex flex-col items-center justify-center bg-[#9A4100] text-white rounded-[14px] px-6 py-3 duration-150 transition-all scale-95">
<span class="material-symbols-outlined mb-1" data-icon="timer" style="font-variation-settings: 'FILL' 1;">timer</span>
<span class="font-label text-[13px] font-semibold">Timer</span>
</button>
<!-- Next -->
<button class="flex flex-col items-center justify-center text-[#574238] dark:text-[#D7C2B5] px-6 py-3 hover:bg-[#ECE7E2] dark:hover:bg-[#252A32] duration-150 transition-all scale-95">
<span class="material-symbols-outlined mb-1" data-icon="arrow_forward">arrow_forward</span>
<span class="font-label text-[13px] font-semibold">Next</span>
</button>
</nav>
</body></html>